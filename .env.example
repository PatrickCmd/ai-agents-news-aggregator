# Database (Supabase) — use the POOLER hosts. The direct db.<project>.supabase.co
# host is IPv6-only on newer Supabase projects and will fail DNS on most networks.
# Session pooler (migrations): port 5432
SUPABASE_DB_URL=postgresql+asyncpg://postgres.<project-ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Transaction pooler (runtime, pgbouncer): port 6543
SUPABASE_POOLER_URL=postgresql+asyncpg://postgres.<project-ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres

# LLM
OPENAI_API_KEY=

# Tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# YouTube proxy (optional)
YOUTUBE_PROXY_ENABLED=false
YOUTUBE_PROXY_USERNAME=
YOUTUBE_PROXY_PASSWORD=

# Email (used in sub-project #2)
RESEND_API_KEY=

# Runtime
LOG_LEVEL=INFO
ENV=dev

# ---------- Sub-project #1 (Ingestion) ----------
# Deploy.py (not used at runtime)
AWS_PROFILE=aiengineer
ECR_REPO_NAME=news-scraper
ECS_CLUSTER=news-aggregator
ECS_SERVICE_NAME=news-scraper

# Runtime
OPENAI_MODEL=gpt-5.4-mini
RSS_MCP_PATH=./rss-mcp/dist/index.js
WEB_SEARCH_MAX_TURNS=15
WEB_SEARCH_SITE_TIMEOUT=120
YOUTUBE_TRANSCRIPT_CONCURRENCY=3
RSS_FEED_CONCURRENCY=5
WEB_SEARCH_SITE_CONCURRENCY=2
